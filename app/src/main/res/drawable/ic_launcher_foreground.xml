<?xml version="1.0" encoding="utf-8"?>
<!-- Insets app_logo.png (a full-bleed square) into the adaptive-icon safe zone, so the
     trophy/ball artwork isn't clipped by circular/squircle/rounded-square launcher masks. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/app_logo"
    android:insetLeft="15%"
    android:insetTop="15%"
    android:insetRight="15%"
    android:insetBottom="15%" />
